<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Extend stock_account Valuation settings block ─────────────────── -->
    <record id="res_config_settings_view_form_odooer" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.odooer.stock</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock_account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <block name="valuation_setting_container" position="inside">
                <setting id="group_odooer_fifo_enabled_setting"
                         help="Links every outgoing delivery to the exact receipts it consumed (FIFO order), regardless of product costing method. Powers historical inventory valuation and the gross profit report.">
                    <field name="group_odooer_fifo_enabled"/>
                    <label for="group_odooer_fifo_enabled" string="FIFO Cost-Flow Tracking"/>
                    <div class="content-group" invisible="not group_odooer_fifo_enabled">
                        <div class="text-muted">
                            After enabling, go to <b>Inventory › Odooer › Reporting › Regenerate FIFO Links</b>
                            to build links for existing historical data.
                        </div>
                    </div>
                </setting>
                <setting id="odooer_product_dropdown_display_name_setting"
                         help="When enabled, product dropdowns (e.g. sale order lines) show [Ref] Name format instead of the tab-separated Name --Ref-- variant.">
                    <field name="odooer_product_dropdown_display_name"/>
                    <label for="odooer_product_dropdown_display_name" string="Standard Display Name in Product Dropdown"/>
                </setting>
            </block>
        </field>
    </record>

</odoo>
