<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_odooer_onhand_report_list" model="ir.ui.view">
        <field name="name">odooer.onhand.report.list</field>
        <field name="model">odooer.onhand.report</field>
        <field name="arch" type="xml">
            <list string="Stock On-Hand" create="false" edit="false" delete="false">
                <header>
                    <button name="action_open_at_date" string="Report at Date"
                            type="object" class="btn-primary" display="always"/>
                </header>
                <field name="product_id"/>
                <field name="categ_id" optional="hide"/>
                <field name="uom_id" optional="hide"/>
                <field name="unit_cost" string="FIFO Unit Cost"
                       widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="onhand_qty" string="On Hand" sum="Total On Hand"/>
                <field name="onhand_value" string="On Hand Value" sum="Total On Hand Value"
                       widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="free_qty" string="Free to Use" sum="Total Free to Use"/>
                <field name="transit_qty" string="In Transit" sum="Total In Transit" optional="hide"/>
                <field name="transit_value" string="Transit Value" sum="Total Transit Value"
                       widget="monetary" options="{'currency_field': 'currency_id'}"
                       optional="hide"/>
                <field name="fifo_remaining_qty" string="Remaining Qty" sum="Total Remaining Qty"/>
                <field name="fifo_remaining_value" string="Remaining Value" sum="Total Remaining Value"
                       widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="True"/>
                <button name="action_open_detail" string="FIFO Detail"
                        type="object" icon="fa-list"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_odooer_onhand_report_pivot" model="ir.ui.view">
        <field name="name">odooer.onhand.report.pivot</field>
        <field name="model">odooer.onhand.report</field>
        <field name="arch" type="xml">
            <pivot string="Stock On-Hand" disable_linking="True">
                <field name="categ_id" type="row"/>
                <field name="product_id" type="row"/>
                <field name="onhand_qty"   type="measure"/>
                <field name="onhand_value" type="measure"/>
                <field name="free_qty"     type="measure"/>
                <field name="transit_qty"  type="measure"/>
                <field name="transit_value" type="measure"/>
                <field name="fifo_remaining_qty"   type="measure"/>
                <field name="fifo_remaining_value" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_odooer_onhand_report_search" model="ir.ui.view">
        <field name="name">odooer.onhand.report.search</field>
        <field name="model">odooer.onhand.report</field>
        <field name="arch" type="xml">
            <search string="Stock On-Hand">
                <field name="product_id"/>
                <field name="categ_id"/>
                <separator/>
                <filter string="Has Transit Stock" name="has_transit"
                        domain="[('transit_qty', '>', 0)]"/>
                <filter string="Out of Stock" name="out_of_stock"
                        domain="[('onhand_qty', '&lt;=', 0)]"/>
                <filter string="Low / No Free Stock" name="low_free"
                        domain="[('free_qty', '&lt;=', 0)]"/>
                <group>
                    <filter string="Product" name="group_product"
                            context="{'group_by': 'product_id'}"/>
                    <filter string="Category" name="group_categ"
                            context="{'group_by': 'categ_id'}"/>
                    <filter string="Company" name="group_company"
                            context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Wizard form -->
    <record id="view_odooer_onhand_report_wizard_form" model="ir.ui.view">
        <field name="name">odooer.onhand.report.wizard.form</field>
        <field name="model">odooer.onhand.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Stock On-Hand at Date">
                <group>
                    <field name="as_of" string="As Of Date"/>
                </group>
                <footer>
                    <button name="open_at_date" string="View Report"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_odooer_onhand_report" model="ir.actions.act_window">
        <field name="name">Stock On-Hand</field>
        <field name="res_model">odooer.onhand.report</field>
        <field name="view_mode">list,pivot</field>
        <field name="context">{}</field>
    </record>

</odoo>
