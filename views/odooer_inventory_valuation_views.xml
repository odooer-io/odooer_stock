<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Inventory Valuation Wizard form ───────────────────────────────── -->
    <record id="view_odooer_inventory_valuation_wizard_form" model="ir.ui.view">
        <field name="name">odooer.inventory.valuation.wizard.form</field>
        <field name="model">odooer.inventory.valuation.wizard</field>
        <field name="arch" type="xml">
            <form string="Historical Inventory Valuation">
                <sheet>
                    <div class="oe_title">
                        <h1>Inventory Valuation</h1>
                    </div>
                    <group>
                        <group>
                            <field name="to_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="line_count" string="Products"/>
                            <field name="total_value" widget="monetary"
                                   options="{'currency_field': 'currency_id'}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <div class="o_row mb-2">
                        <button name="action_compute" type="object"
                                string="Compute" class="btn-primary"/>
                    </div>
                    <notebook>
                        <page string="Valuation Lines" name="lines">
                            <field name="line_ids" readonly="1">
                                <list decoration-muted="qty_on_hand == 0">
                                    <field name="categ_id" optional="show"/>
                                    <field name="product_id"/>
                                    <field name="cost_method" optional="show"/>
                                    <field name="qty_on_hand" sum="Total Qty"/>
                                    <field name="uom_id" optional="show"/>
                                    <field name="unit_cost"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="total_value" widget="monetary"
                                           options="{'currency_field': 'currency_id'}"
                                           sum="Total Value"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────────── -->
    <record id="action_odooer_inventory_valuation" model="ir.actions.act_window">
        <field name="name">Inventory Valuation (Odooer)</field>
        <field name="res_model">odooer.inventory.valuation.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{}</field>
    </record>

</odoo>
