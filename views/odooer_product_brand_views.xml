<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Search view ───────────────────────────────────────────────────── -->
    <record id="odooer_product_brand_search" model="ir.ui.view">
        <field name="name">odooer_stock.product.brand.search</field>
        <field name="model">odooer_stock.product.brand</field>
        <field name="arch" type="xml">
            <search string="Product Brands">
                <field name="name" string="Brand"/>
            </search>
        </field>
    </record>

    <!-- ── Action (must be defined before form view uses %(...)d) ────────── -->
    <record id="odooer_product_brand_action" model="ir.actions.act_window">
        <field name="name">Product Brands</field>
        <field name="res_model">odooer_stock.product.brand</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="odooer_product_brand_search"/>
    </record>

    <!-- ── Form view ─────────────────────────────────────────────────────── -->
    <record id="odooer_product_brand_form" model="ir.ui.view">
        <field name="name">odooer_stock.product.brand.form</field>
        <field name="model">odooer_stock.product.brand</field>
        <field name="arch" type="xml">
            <form string="Product Brand">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(odooer_product_brand_action)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-cubes"
                                context="{'search_default_brand_id': id}"
                                invisible="product_count == 0">
                            <field name="product_count" string="Products" widget="statinfo"/>
                        </button>
                    </div>
                    <field name="image" widget="image"
                           class="oe_avatar"
                           options="{'image_preview': 'image'}"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Brand Name"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── List view ─────────────────────────────────────────────────────── -->
    <record id="odooer_product_brand_list" model="ir.ui.view">
        <field name="name">odooer_stock.product.brand.list</field>
        <field name="model">odooer_stock.product.brand</field>
        <field name="arch" type="xml">
            <list string="Product Brands" editable="top">
                <field name="name"/>
                <field name="product_count" string="Products"/>
            </list>
        </field>
    </record>


</odoo>
